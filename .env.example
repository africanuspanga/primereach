# PrimeReach Global Solutions — environment variables
#
# Local dev/seed: copy this file to `.env.local` and fill in the real values.
# Production (Vercel): add each of these in
#   Vercel → Project → Settings → Environment Variables (Production + Preview).
#
# The real values for THIS project are kept in `.env.local` (gitignored — never
# commit real keys). This example file is safe to commit.

# ---------------------------------------------------------------------------
# Supabase project URL — public, exposed to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Supabase anon / public key — safe to expose to the browser (RLS enforced).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Supabase service_role key — SERVER ONLY. Full database access; bypasses RLS.
# Never expose this to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Shared secret for the on-demand revalidation webhook (POST /api/revalidate).
# Generate a long random string, e.g. `openssl rand -hex 24`.
REVALIDATE_SECRET=generate-a-long-random-string
